{
  "$schema": "https://railway.app/standard-schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "phases": {
        "setup": {
          "nixPkgs": [
            "python312",
            "freetype",
            "libjpeg",
            "zlib",
            "pkg-config",
            "gcc"
          ]
        }
      }
    }
  },
  "deploy": {
    "startCommand": "gunicorn config.wsgi:application --bind 0.0.0.0:$PORT",
    "restartPolicyType": "ON_FAILURE"
  }
}
